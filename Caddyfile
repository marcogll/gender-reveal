:80 {
  handle /api/vote {
    reverse_proxy https://flows.soul23.cloud {
      header_up Host flows.soul23.cloud
      rewrite /webhook/87701460-f93a-4303-a6f4-83ff280967cc
    }
  }

  handle /api/results {
    reverse_proxy https://flows.soul23.cloud {
      header_up Host flows.soul23.cloud
      rewrite /webhook/90053c16-2247-4b5c-95d5-628d90813b14
    }
  }

  root * /srv
  encode zstd gzip
  file_server
}
